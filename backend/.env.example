# Copy to backend/.env for local dev. Never commit the real .env.
# All app settings are namespaced FIXFLOW_* and read by app/core/config.py.

# Database — SQLAlchemy async URL. For local Docker Compose:
FIXFLOW_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fixflow
# For Supabase Postgres later (Project Settings → Database → Connection string,
# pick "URI" and prepend the driver):
# FIXFLOW_DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@<host>:5432/postgres

# Cloudflare R2 — media object storage (S3-compatible). Backend-only creds;
# never ship them to the mobile app. Create an R2 API token in the Cloudflare
# dashboard (R2 → Manage API Tokens). Account ID is shown on the R2 overview.
FIXFLOW_R2_ACCOUNT_ID=
FIXFLOW_R2_ACCESS_KEY_ID=
FIXFLOW_R2_SECRET_ACCESS_KEY=
FIXFLOW_R2_BUCKET=job-media
# Max accepted upload size (bytes); finalize rejects + purges anything larger.
FIXFLOW_R2_MAX_UPLOAD_BYTES=31457280

# Auth — HS256 secret for signing login JWTs. Generate a long random string for
# production (e.g. `openssl rand -hex 32`); the app's built-in default is for
# local dev only.
FIXFLOW_JWT_SECRET=
# Token lifetime in minutes (default 30 days).
# FIXFLOW_JWT_EXPIRE_MINUTES=43200

# CORS — JSON-encoded list of allowed origins for the manager web app + Expo dev.
FIXFLOW_CORS_ORIGINS=["http://localhost:5173","http://localhost:8081"]

# Nightly DB backup (pg_dump -> R2 under FIXFLOW_BACKUP_PREFIX). On by default;
# runs on the in-process scheduler at 02:30 shop time. docs/RUNBOOK-BACKUPS.md.
# FIXFLOW_BACKUP_ENABLED=true
# FIXFLOW_BACKUP_RETENTION_DAYS=30

# ── Ops console (the standalone read-only ops/admin app) ─────────────────────
# All optional: leave empty and the matching tab reports "not configured"
# instead of failing. The backend proxies these so the ops app — and the
# teammates you hand it to — never see the tokens.

# Railway API (logs / deployments / resource metrics). Token: Railway dashboard
# → Account Settings → Tokens (account or team scope). Project/Environment IDs:
# Railway project → Settings (or the URL). Service IDs map is optional.
# FIXFLOW_RAILWAY_API_TOKEN=
# FIXFLOW_RAILWAY_PROJECT_ID=
# FIXFLOW_RAILWAY_ENVIRONMENT_ID=
# FIXFLOW_RAILWAY_SERVICE_IDS={"web":"<id>","backend":"<id>","ops":"<id>"}

# Sentry issues feed — a READ auth token (sentry.io → Settings → Auth Tokens,
# scopes event:read + project:read). This is NOT the ingest DSN above.
# FIXFLOW_SENTRY_AUTH_TOKEN=
# FIXFLOW_SENTRY_ORG=
# FIXFLOW_SENTRY_PROJECT_WEB=
# FIXFLOW_SENTRY_PROJECT_BACKEND=
# FIXFLOW_SENTRY_PROJECT_MOBILE=
