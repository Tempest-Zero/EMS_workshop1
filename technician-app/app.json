{
  "expo": {
    "name": "FixFlow Technician",
    "slug": "fixflow-technician",
    "owner": "instant_fidelity",
    "version": "0.1.0",
    "orientation": "portrait",
    "platforms": [
      "android"
    ],
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "android": {
      "package": "com.fixflow.technician",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-video",
      [
        "expo-image-picker",
        {
          "cameraPermission": "FixFlow needs the camera to capture before/after proof of repairs.",
          "microphonePermission": "FixFlow needs the microphone to record before/after videos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FixFlow records your location when you clock in, to flag punches made away from the workshop."
        }
      ],
      "expo-audio",
      "expo-notifications",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "eb1d2f9f-2427-4aaf-934b-0e996b290692"
      }
    }
  }
}
